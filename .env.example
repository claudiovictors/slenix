# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_NAME=Slenix
APP_KEY=
APP_DEBUG=true
APP_ENV=local                      # options: local, production, testing
APP_PATH=/
APP_VERSION=2.6
APP_BASE_URL=http://localhost
APP_DOMAIN=localhost

# Timezone & Localization
# Refer to: https://www.php.net/manual/en/timezones.php
APP_TIMEZONE=UTC
APP_LOCALE=en

# -----------------------------------------------------------------------------
# Database Connection
# Supports: MySQL and PostgreSQL
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=slenix_db
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=                             # Generate a safe random string

APP_AUTH_GUARD=web                      # options: web (session), api (jwt)

# -----------------------------------------------------------------------------
# Mail Service Settings
# Driver options: mail, smtp
# -----------------------------------------------------------------------------
EMAIL_METHOD=smtp                       # options: mail, smtp
SMTP_HOST=smtp.gmail.io
SMTP_PORT=587
SMTP_USERNAME=null
SMTP_PASSWORD=null
SMTP_ENCRYPTION=tls    # options: tls, ssl, none
SMTP_AUTH=true
SMTP_TIMEOUT=30

MAIL_FROM_ADDRESS="hello@slenix.dev"
MAIL_FROM_NAME=Slenix

# -----------------------------------------------------------------------------
# Locale Disk
# -----------------------------------------------------------------------------
STORAGE_DISK=public

# -----------------------------------------------------------------------------
# Uploads
# -----------------------------------------------------------------------------
UPLOAD_MAX_SIZE=10485760 #10MB
UPLOAD_DISK=public
UPLOAD_PATH=uploads

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
CACHE_DRIVER=file
CACHE_TTL=3600 #1h
CACHE_PREFIX=slenix_

# -----------------------------------------------------------------------------
# HTTP & Performance
# -----------------------------------------------------------------------------
FORCE_HTTPS=false
TRUSTED_PROXIES=                        # Use '*' or comma-separated IPs
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# -----------------------------------------------------------------------------
# Content Security Policy (CSP)
# -----------------------------------------------------------------------------
CSP_ENABLED=true
CSP_POLICY="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline';"

# -----------------------------------------------------------------------------
# Loogs
# -----------------------------------------------------------------------------
LOG_CHANNEL=slenix
LOG_LEVEL=debug # debug | info | warning | error
LOG_DAYS=30