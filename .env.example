# =============================================================================
# Slenix Framework — Environment Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Slenix
APP_KEY=
APP_ENV=local                       # local | production | testing
APP_DEBUG=true
APP_VERSION=3.0
APP_BASE_URL=http://localhost
APP_DOMAIN=localhost
APP_PATH=/

# Timezone & Localization
# See: https://www.php.net/manual/en/timezones.php
APP_TIMEZONE=UTC
APP_LOCALE=en


# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
APP_AUTH_GUARD=web
JWT_SECRET=


# -----------------------------------------------------------------------------
# Database
# Supports: mysql, pgsql
# -----------------------------------------------------------------------------
DB_CONNECTION=sqlite
#DB_HOST=127.0.0.1
#DB_PORT=3306
DB_DATABASE=database/database.sqlite               # slenix.db | database.sqlite
#DB_USERNAME=root
#DB_PASSWORD=
#DB_CHARSET=utf8mb4
#DB_COLLATION=utf8mb4_unicode_ci


# -----------------------------------------------------------------------------
# Mail
# Driver options: mail | smtp
# -----------------------------------------------------------------------------
EMAIL_METHOD=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=null
SMTP_PASSWORD=null
SMTP_ENCRYPTION=tls                 # tls | ssl | none
SMTP_AUTH=true
SMTP_TIMEOUT=30

MAIL_FROM_ADDRESS="hello@slenix.dev"
MAIL_FROM_NAME=Slenix


# -----------------------------------------------------------------------------
# Storage & Uploads
# -----------------------------------------------------------------------------
STORAGE_DISK=public

UPLOAD_DISK=public
UPLOAD_PATH=uploads
UPLOAD_MAX_SIZE=10485760            # 10 MB in bytes


# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
CACHE_DRIVER=file
CACHE_TTL=3600                      # seconds (1 hour)
CACHE_PREFIX=slenix_


# -----------------------------------------------------------------------------
# HTTP & Performance
# -----------------------------------------------------------------------------
FORCE_HTTPS=false
TRUSTED_PROXIES=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60                # seconds


# -----------------------------------------------------------------------------
# Content Security Policy (CSP)
# -----------------------------------------------------------------------------
# In local/development: allows external CDNs for convenience
# In production: restrict to 'self' only — configure explicitly
# -----------------------------------------------------------------------------
CSP_ENABLED=false
CSP_POLICY="default-src 'self' *; style-src 'self' 'unsafe-inline' *; font-src 'self' data: *; script-src 'self' 'unsafe-inline' 'unsafe-eval' *; img-src 'self' data: blob: *; connect-src 'self' *; media-src 'self' *; frame-src 'self' *;"

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=slenix
LOG_LEVEL=debug                     # debug | info | warning | error
LOG_DAYS=30