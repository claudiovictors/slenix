# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
APP_NAME=Slenix
APP_KEY=
APP_DEBUG=true
APP_ENV=local                      # options: local, production, testing
APP_PATH=/
APP_VERSION=2.4
APP_BASE_URL=http://localhost
APP_DOMAIN=localhost

# Timezone & Localization
# Refer to: https://www.php.net/manual/en/timezones.php
APP_TIMEZONE=Africa/Luanda
APP_LOCALE=pt_AO

# -----------------------------------------------------------------------------
# Database Connection
# Supports: MySQL and PostgreSQL
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=slenix_db
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# -----------------------------------------------------------------------------
# Security & Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your_super_secret_key_here

# -----------------------------------------------------------------------------
# Mail Service Settings
# Driver options: mail, smtp
# -----------------------------------------------------------------------------
MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls                # options: tls, ssl, none
MAIL_FROM_ADDRESS="hello@slenix.dev"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Locale Disk
# -----------------------------------------------------------------------------
STORAGE_DISK=public

# -----------------------------------------------------------------------------
# Uploads
# -----------------------------------------------------------------------------
UPLOAD_MAX_SIZE=10485760 #10MB
UPLOAD_DISK=public
UPLOAD_PATH=uploads

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
CACHE_DRIVER=file
CACHE_TTL=3600 #1h
CACHE_PREFIX=slenix_

# -----------------------------------------------------------------------------
# HTTP & Performance
# -----------------------------------------------------------------------------
FORCE_HTTPS=false
TRUSTED_PROXIES=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60

# -----------------------------------------------------------------------------
# Content Security Policy (CSP)
# -----------------------------------------------------------------------------
CSP_ENABLED=true
CSP_POLICY="default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline';"

# -----------------------------------------------------------------------------
# Loogs
# -----------------------------------------------------------------------------
LOG_CHANNEL=slenix
LOG_LEVEL=debug # debug | info | warning | error
LOG_DAYS=30