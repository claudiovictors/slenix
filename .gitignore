# --- Dependencies ---
# Composer dependencies should be managed via composer.json
/vendor/

# --- Environment & Secrets ---
# Sensitive environment files must never be tracked in the repository
.env
.env.backup
/storage/*.key

# --- Package Locks & Meta ---
# Locks the versions of dependencies (optional to ignore depending on workflow)
composer.lock
ws-server.php

# --- Logs and Caches ---
# Temporary runtime files generated by the application
*.log
*.cache
/storage/logs/*
!/storage/logs/.gitkeep

# --- IDE & OS Metadata ---
# Project-specific settings for editors and operating systems
.DS_Store
.idea/
.vscode/
.phpunit.result.cache