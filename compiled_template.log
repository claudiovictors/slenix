<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <title><?php echo htmlspecialchars($title, ENT_QUOTES, 'UTF-8'); ?></title>
</head>
<body>
    <h1><?php echo htmlspecialchars($title, ENT_QUOTES, 'UTF-8'); ?></h1>

    <!-- Usando isset() para verificar usuário logado -->
    <?php if(isset($user): ?>)
        <p>Bem-vindo, <?php echo htmlspecialchars($user, ENT_QUOTES, 'UTF-8'); ?>!</p>
    <?php else: ?>
        <p>Você não está logado.</p>
    <?php endif; ?>

    <!-- Usando count() para verificar lista de itens -->
    <?php if(count($items): ?> > 0)
        <p>Você tem <?php echo htmlspecialchars(count($items), ENT_QUOTES, 'UTF-8'); ?> itens:</p>
        <ul>
        <?php foreach($items as $item): ?>
            <li><?php echo htmlspecialchars($item['name'], ENT_QUOTES, 'UTF-8'); ?> - R$ <?php echo htmlspecialchars($item['price'], ENT_QUOTES, 'UTF-8'); ?></li>
        <?php endforeach; ?>
        </ul>
    <?php else: ?>
        <p>Nenhum item disponível.</p>
    <?php endif; ?>
</body>
</html>